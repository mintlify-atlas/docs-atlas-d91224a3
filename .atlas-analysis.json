  "keyFeatures": [
    "Multiple instrumentation modes (LLVM, LTO, GCC plugin)",
    "Binary-only fuzzing with QEMU, FRIDA, Unicorn, and Nyx",
    "CmpLog and LAF-Intel for enhanced mutation",
    "Persistent mode and shared memory test cases",
    "Custom mutators (C/C++, Python, Rust)",
    "AFLfast power schedules and MOpt mutators",
    "NeverZero coverage and non-colliding instrumentation",
    "Parallel fuzzing support",
    "Cross-platform support (Linux, BSD, macOS, Android)"
  ],
  "publicApiSurface": [
    "afl-cc / afl-c++ - Compiler wrappers for instrumentation",
    "afl-fuzz - Main fuzzing engine",
    "afl-showmap - Coverage map display",
    "afl-tmin - Test case minimizer",
    "afl-cmin - Corpus minimizer",
    "afl-analyze - Input file analyzer",
    "afl-whatsup - Multi-fuzzer status monitor",
    "afl-plot - Generate fuzzing progress plots",
    "afl-system-config - System configuration helper",
    "afl-gotcpu - CPU availability checker",
    "Custom mutator API (C/C++, Python)",
    "Environment variables (AFL_* configuration options)"
  ]
